# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to run in in-memory mode (Vercel / local demo)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# Alternative: POSTGRES_URL=...
# Alternative: NEON_DATABASE_URL=...
REVENUEPILOT_DB=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=10
# Set to 1 to skip running migrations on startup (e.g. read-only replicas)
REVENUEPILOT_SKIP_DB_MIGRATION=0

# ── AI provider ───────────────────────────────────────────────────────────────
REVENUEPILOT_AI_PROVIDER=deterministic
# Options: deterministic | anthropic | openai
ANTHROPIC_API_KEY=
# OpenAI provider (REVENUEPILOT_AI_PROVIDER=openai)
OPENAI_API_KEY=
REVENUEPILOT_OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # optional: Azure / OpenAI-compatible gateway
REVENUEPILOT_MODEL=claude-sonnet-4-6
REVENUEPILOT_AI_TIMEOUT=60
REVENUEPILOT_AI_MAX_RETRIES=2

# ── Security ──────────────────────────────────────────────────────────────────
# Leave blank to disable API-key enforcement (development only)
REVENUEPILOT_API_KEY=
API_KEY_HEADER=X-API-Key
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=*

# ── Rate Limiting / Runtime ───────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
# Rate-limit backend: memory (default, per-instance) or redis (shared/global)
RATE_LIMIT_BACKEND=memory
# REDIS_URL=redis://localhost:6379/0  # required when RATE_LIMIT_BACKEND=redis
REVENUEPILOT_REQUEST_TIMEOUT=30
REVENUEPILOT_MAX_REQUEST_BODY_SIZE=1000000

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text
METRICS_ENABLED=false
